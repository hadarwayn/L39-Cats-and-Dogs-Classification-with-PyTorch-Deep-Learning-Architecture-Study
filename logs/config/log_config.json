{
  "version": 1,
  "ring_buffer": {
    "max_bytes": 5242880,
    "max_files": 3,
    "backup_count": 2
  },
  "formatters": {
    "standard": {
      "format": "%(asctime)s [%(levelname)s] %(name)s: %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "log_file": "logs/training.log",
  "console_level": "INFO",
  "file_level": "DEBUG"
}
